{
    "version": 2,
    "builds": [{ "src": "api/index.js", "use": "@vercel/node" }],
    "routes": [
      { "src": "/signup", "dest": "api/index.js" },
      { "src": "/login", "dest": "api/index.js" },
      { "src": "/logout", "dest": "api/index.js" },
      { "src": "/verify", "dest": "api/index.js" },
      { "src": "/forgot", "dest": "api/index.js" },
      { "src": "/reset/(.*)", "dest": "api/index.js" },
      { "src": "/auth/(.*)", "dest": "api/index.js" },
      { "src": "/account/(.*)", "dest": "api/index.js" },
      { "src": "/api/(.*)", "dest": "api/index.js" },
      { "src": "/admin/(.*)", "dest": "api/index.js" },
      { "src": "/resources/(.*)", "dest": "api/index.js" },
      { "src": "/list/(.*)", "dest": "api/index.js" },
      { "src": "/(.*)", "dest": "/public/$1" }
    ]
  }